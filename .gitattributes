# Normalize line endings to LF for consistency across platforms
* text=auto

# Ensure shell scripts always have LF line endings
*.sh text eol=lf
hooks/session-start text eol=lf

# Ensure the polyglot wrapper keeps LF (it's parsed by both cmd and bash)
*.cmd text eol=lf

# Text files
*.md text eol=lf
*.txt text eol=lf
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.cs text eol=lf

# Binary files
*.dll binary
*.exe binary
*.png binary
*.jpg binary
*.gif binary